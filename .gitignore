# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you may want to ignore it.
# .python-version

# pipenv
#   According to pypa/pipenv#1172, the Pipfile.lock should be committed.
#   But for a library, you should not commit Pipfile.lock.
#Pipfile.lock

# poetry
#   Poetry uses poetry.lock to ensure reproducible builds.
#   But for a library, you should not commit poetry.lock.
#poetry.lock

